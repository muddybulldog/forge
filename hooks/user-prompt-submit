#!/usr/bin/env python3
"""forge UserPromptSubmit hook (Codex session awareness) — injects live run state.

On each prompt, if the session cwd has a `.forge/runs/` with a live or
recently-terminal run, emit a compact status block as `additionalContext` so the
Codex orchestrator never operates on stale memory. Otherwise emit nothing.

Reads files only — no subprocess, no runner invocation — and never blocks a
prompt: any error is swallowed to a stderr note with exit 0. Shares its renderer
with `forge-run.py --status` via `scripts/forge_status.py`.

Wired via the shared plugin `hooks/hooks.json` (auto-installed on both harnesses,
like `session-start`). Session awareness is a Codex feature — Claude Code handles
it natively — so a best-effort harness gate keeps this SILENT under Claude: its
UserPromptSubmit input carries `transcript_path` (Codex's carries `turn_id`
instead). When the signal is ambiguous the hook fires (it degrades to firing in
both, which is harmless — silent whenever there's no active run).
"""
import json
import os
import sys
import time

_SCRIPTS = os.path.join(
    os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "scripts"
)


def _is_claude(hook_input):
    """Best-effort: suppress under Claude Code (its hook input carries
    `transcript_path` and no Codex `turn_id`). Err toward firing when unsure."""
    if not isinstance(hook_input, dict):
        return False
    return bool(hook_input.get("transcript_path")) and not hook_input.get("turn_id")


def main():
    # Codex/Claude deliver the hook input as JSON on stdin; we read it to gate on
    # harness, and otherwise only need the session cwd (our own working dir).
    raw = ""
    try:
        raw = sys.stdin.read()
    except Exception:  # noqa: BLE001 - stdin is best-effort, never fatal
        raw = ""
    hook_input = {}
    if raw.strip():
        try:
            hook_input = json.loads(raw)
        except Exception:  # noqa: BLE001 - malformed input -> treat as ambiguous
            hook_input = {}
    if _is_claude(hook_input):
        return 0  # Claude has native session awareness; this hook is Codex-only

    try:
        runs = os.path.join(os.getcwd(), ".forge", "runs")
        if not os.path.isdir(runs):
            return 0
        names = [n for n in os.listdir(runs) if os.path.isdir(os.path.join(runs, n))]
        if not names:
            return 0
        latest = os.path.join(runs, max(names))  # dir names are sortable timestamps

        if _SCRIPTS not in sys.path:
            sys.path.insert(0, _SCRIPTS)
        import forge_status

        state = forge_status.read_run_state(latest)
        if state is None:
            return 0
        block = forge_status.render_hook_block(state, now=time.time())
        if not block:
            return 0
        print(json.dumps({
            "hookSpecificOutput": {
                "hookEventName": "UserPromptSubmit",
                "additionalContext": block,
            }
        }))
    except Exception as e:  # noqa: BLE001 - a broken hook must never block a prompt
        sys.stderr.write("forge hook: {}\n".format(e))
        return 0
    return 0


if __name__ == "__main__":
    sys.exit(main())
